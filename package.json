{
  "name": "@mainwp/mcp",
  "version": "1.0.0-beta.1",
  "description": "MCP Server for MainWP Dashboard - Exposes MainWP Abilities API as MCP tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mainwp-mcp": "dist/index.js",
    "mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "settings.schema.json",
    "settings.example.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:evals": "vitest run tests/evals/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:manual": "tsx scripts/manual-test.ts",
    "check-version": "node scripts/check-version.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mainwp",
    "mcp",
    "model-context-protocol",
    "wordpress",
    "ai"
  ],
  "author": "MainWP",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mainwp/mainwp-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mainwp/mainwp-mcp/issues"
  },
  "homepage": "https://github.com/mainwp/mainwp-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
